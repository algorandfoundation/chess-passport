# Public gateway for the application
EXPO_PUBLIC_GATEWAY_URL=https://credentials.shore-tech.net

# Algorand network genesis
EXPO_PUBLIC_GENESIS_ID=dockernet-v1

# Algorand node (LocalNet exposed via shore-tech)
EXPO_PUBLIC_ALGOD_URL=https://localnet.shore-tech.net
EXPO_PUBLIC_ALGOD_TOKEN=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

# Algorand indexer (used to fetch transaction history for the user's
EXPO_PUBLIC_INDEXER_URL=https://localnet-indexer.shore-tech.net
EXPO_PUBLIC_INDEXER_TOKEN=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

# Pre-minted chess-gateway JWT (obtained out-of-band by signing in against
# the gateway with the UserRole prior to launching the app). The app uses
# this value directly as the `Authorization: Bearer` token for authenticated
# requests (e.g. `/v1/wallet/users/:user_id/`); no `/v1/auth/sign-in/`
# round-trip is performed at runtime.
EXPO_PUBLIC_GATEWAY_USER_SECRET_TOKEN=someGatewayJwt
